+    def __init__(self, repository, payment_gateway):
+        self.repository = repository
+        self.payment_gateway = payment_gateway
+
+    def process_order(self, user_id: str, items: list[dict]) -> Optional[OrderResult]:
+        """Process a new order with payment validation."""
+        if not items:
+            logger.warning("Empty order attempt by user %s", user_id)
+            return None
+
+        total = sum(item["price"] * item["quantity"] for item in items)
+        order = self.repository.create(user_id=user_id, total=total)
+        self.payment_gateway.charge(user_id, total)
+        logger.info("Order %s processed: %.2f", order.id, total)
+        return OrderResult(order_id=order.id, total=total, status="completed")

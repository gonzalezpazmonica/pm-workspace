{
  "env": {
    "AZURE_DEVOPS_EXT_PAT": "$(cat $HOME/.azure/devops-pat 2>/dev/null || echo 'PAT_NOT_CONFIGURED')"
  },
  "permissions": {
    "allow": [
      "Bash(az devops:*)",
      "Bash(az boards:*)",
      "Bash(az repos:*)",
      "Bash(az pipelines:*)",
      "Bash(az account:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(date:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "WebSearch",
      "Bash(git:*)",
      "Bash(bash:*)",
      "WebFetch(domain:support.claude.com)",
      "Bash(./scripts/emergency-plan.sh:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh merge:*)",
      "Bash(gh pr merge:*)",
      "Bash(bats:*)",
      "Bash(wc:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(npx vitest:*)",
      "Bash(npm install:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vite:*)",
      "Bash(E2E_BRIDGE_URL=\"http://localhost:8081\" npx playwright test --reporter=list 2>&1 | tail -40)",
      "Bash(E2E_BRIDGE_URL=\"http://localhost:8081\" npx playwright test --reporter=list 2>&1 | grep -E \"\\(passed|failed|skipped\\)\" | tail -3)",
      "Bash(E2E_BRIDGE_URL=\"http://localhost:8081\" npx playwright test --reporter=list 2>&1 | grep -E \"✓|×|·\" | head -20)",
      "Bash(E2E_BRIDGE_URL=\"http://localhost:8081\" npx playwright test --reporter=line 2>&1 | grep -c \"passed\\\\|failed\" | head -1)",
      "Bash(E2E_BRIDGE_URL=\"http://localhost:8081\" npx playwright test --reporter=line 2>&1 | tail -3)",
      "Bash(kill:*)",
      "Bash(BASE_URL=\"http://localhost:8081\" npx playwright test --reporter=line 2>&1 | tail -10)",
      "Bash(BASE_URL=\"http://localhost:8081\" npx playwright test --reporter=line 2>&1 | grep -E \"^\\\\s+\\\\d+ \\(passed|failed|skipped\\)\")",
      "Bash(BASE_URL=\"http://localhost:8081\" npx playwright test --reporter=list 2>&1 | grep -E \"passed|failed\" | tail -5)",
      "Bash(BASE_URL=\"http://localhost:8081\" npx playwright test e2e/login.spec.ts --reporter=line 2>&1 | tail -15)",
      "Bash(npx playwright:*)",
      "Bash(for f:*)",
      "Bash(cd:*)",
      "Bash(./node_modules/.bin/playwright test:*)",
      "WebFetch(domain:github.com)",
      "Bash(sed:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(chmod:*)",
      "Bash(sudo:*)"
    ]
  }
}

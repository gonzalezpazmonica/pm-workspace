{
  "env": {
    "AZURE_DEVOPS_EXT_PAT": "$(cat $HOME/.azure/devops-pat 2>/dev/null || echo 'PAT_NOT_CONFIGURED')"
  },
  "permissions": {
    "allow": [
      "Bash(az devops:*)",
      "Bash(az boards:*)",
      "Bash(az repos:*)",
      "Bash(az pipelines:*)",
      "Bash(az account:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(date:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "WebSearch",
      "Bash(git:*)",
      "Bash(bash:*)",
      "WebFetch(domain:support.claude.com)",
      "Bash(./scripts/emergency-plan.sh:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh pr merge:*)",
      "Bash(bats:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vite:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(kill:*)",
      "Bash(cd:*)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(chmod:*)",
      "Bash(sudo:*)"
    ]
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRITERIO Entry Schema",
  "type": "object",
  "required": ["id", "ambito", "principio", "dureza", "provenance"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CRIT-\\d{3}$"
    },
    "ambito": {
      "type": "string",
      "enum": ["tecnicas", "comunicacion", "priorizacion", "riesgo", "delegacion"]
    },
    "principio": {
      "type": "string",
      "minLength": 10
    },
    "ejemplos": {
      "type": "string"
    },
    "contraejemplos": {
      "type": "string"
    },
    "dureza": {
      "type": "string",
      "enum": ["linea_roja", "preferencia", "estilo"]
    },
    "provenance": {
      "type": "string",
      "const": "human_authored"
    }
  }
}
